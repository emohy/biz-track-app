rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidTimestamp(field) {
      return field is timestamp || field == request.time;
    }

    // Rules for user data
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Products collection
      match /products/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId
          && request.resource.data.createdAt == request.time
          && validateProduct(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.createdAt == resource.data.createdAt
          && (request.resource.data.updatedAt == request.time || request.resource.data.updatedAt == resource.data.updatedAt)
          && validateProduct(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // Sales collection
      match /sales/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId
          && request.resource.data.createdAt == request.time
          && validateSale(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.createdAt == resource.data.createdAt
          // Sales items and total amount should be immutable once created for integrity
          && request.resource.data.productId == resource.data.productId
          && request.resource.data.totalAmount == resource.data.totalAmount
          && (request.resource.data.updatedAt == request.time || request.resource.data.updatedAt == resource.data.updatedAt)
          && validateSale(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // Customers collection
      match /customers/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId
          && request.resource.data.createdAt == request.time
          && validateCustomer(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.createdAt == resource.data.createdAt
          && (request.resource.data.updatedAt == request.time || request.resource.data.updatedAt == resource.data.updatedAt)
          && validateCustomer(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // Expenses collection
      match /expenses/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) 
          && request.resource.data.userId == userId
          && request.resource.data.createdAt == request.time
          && validateExpense(request.resource.data);
        allow update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.createdAt == resource.data.createdAt
          && (request.resource.data.updatedAt == request.time || request.resource.data.updatedAt == resource.data.updatedAt)
          && validateExpense(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    // Top-level loans collection
    match /loans/{loanId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Repayment sub-collection
      match /repayments/{repaymentId} {
        allow read: if isSignedIn() && get(/databases/$(database)/documents/loans/$(loanId)).data.userId == request.auth.uid;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/loans/$(loanId)).data.userId == request.auth.uid;
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/loans/$(loanId)).data.userId == request.auth.uid;
      }
    }

    function isNum(val) {
      return val is number || val is int;
    }

    function validateProduct(data) {
      return data.productName is string && data.productName.size() > 0
        && isNum(data.sellingPrice) && data.sellingPrice >= 0
        && isNum(data.costPrice) && data.costPrice >= 0
        && isNum(data.stockQuantity);
    }

    function validateSale(data) {
      return data.productId is string
        && isNum(data.quantitySold) && data.quantitySold > 0
        && isNum(data.totalAmount) && data.totalAmount >= 0
        && data.paymentStatus in ['Paid', 'Partial', 'Unpaid']
        && isNum(data.amountPaid) && data.amountPaid >= 0;
    }

    function validateCustomer(data) {
      return data.keys().hasOnly(['userId', 'createdAt', 'updatedAt', 'name', 'phone', 'isDeleted', 'deletedAt'])
        && data.name is string && data.name.size() > 0
        && (data.phone == null || data.phone is string);
    }

    function validateExpense(data) {
      return data.keys().hasOnly(['userId', 'createdAt', 'updatedAt', 'description', 'amount', 'category', 'isDeleted', 'deletedAt'])
        && data.description is string
        && isNum(data.amount) && data.amount >= 0;
    }
  }
}
